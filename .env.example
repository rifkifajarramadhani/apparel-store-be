# Copy this file to .env for local development. Never commit real credentials.
APP_ENVIRONMENT=development

DATABASE_PASSWORD=local-development-only
AUTH_JWT_ACCESS_SECRET=local-access-secret-change-me
AUTH_JWT_REFRESH_SECRET=local-refresh-secret-change-me
REDIS_PASSWORD=
MAIL_PASSWORD=

# Storefront integration: first verified user with this email becomes admin.
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# Comma-separated browser origins allowed by CORS (the storefront dev server).
APP_CORS_ORIGINS=http://localhost:3000
